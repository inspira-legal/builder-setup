{
  "name": "builder-setup",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/setup.ts",
    "build": "bun run scripts/build.ts",
    "lint": "oxlint src/ scripts/",
    "format": "oxfmt src/ scripts/",
    "format:check": "oxfmt --check src/ scripts/",
    "check": "bun run lint && bun run format:check && bun --bun tsc"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "lefthook": "^2.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2"
  }
}
